<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHabit"
        app:strokeWidth="2dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/imgHabitIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtHabitName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="8dp"
                android:text="Drink Water"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/imgHabitIcon"
                app:layout_constraintTop_toTopOf="@id/imgHabitIcon"
                app:layout_constraintEnd_toStartOf="@id/txtStatus" />

            <TextView
                android:id="@+id/txtStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtHabitDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:text="Stay hydrated throughout the day"
                app:layout_constraintTop_toBottomOf="@id/txtHabitName"
                app:layout_constraintStart_toEndOf="@id/imgHabitIcon"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/txtProgressLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Progress"
                app:layout_constraintTop_toBottomOf="@id/imgHabitIcon"
                app:layout_constraintStart_toStartOf="parent" />

            <TextView
                android:id="@+id/txtProgressValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 / 8 glasses"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="@id/txtProgressLabel"
                app:layout_constraintEnd_toEndOf="parent" />

            <ProgressBar
                android:id="@+id/progressBarHabit"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="8"
                android:progress="3"
                app:layout_constraintTop_toBottomOf="@id/txtProgressLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <Button
                android:id="@+id/btnMinus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="-"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="0dp"

                android:textColor="@color/black"
                app:cornerRadius="50dp"

                app:layout_constraintTop_toBottomOf="@id/progressBarHabit"
                app:layout_constraintEnd_toStartOf="@id/btnPlus"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnPlus"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:text="+"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="0dp"

                app:cornerRadius="50dp"
                android:textColor="@color/black"

                app:layout_constraintTop_toBottomOf="@id/progressBarHabit"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>